# ── Local dev ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://mbx:Nopassword123!@localhost:5432/ocworkspace"

# ── Docker (docker-compose uses these) ────────────────────────────────────────
POSTGRES_USER=ocworkspace
POSTGRES_PASSWORD=ocworkspace
